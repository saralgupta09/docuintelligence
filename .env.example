# ============================================================
# DocuIntel — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is gitignored — never commit real API keys.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=DocuIntel
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ── Storage Paths ────────────────────────────────────────────
# Relative to where you run uvicorn (the backend/ directory)
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Embedding Model ──────────────────────────────────────────
# Use bge-small for Phase 1 (fast, free, local)
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── Chunking ─────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_COLLECTION_NAME=documents

# ── Future Phases ────────────────────────────────────────────
# Uncomment and fill in when you reach Phase 2/3:
# GEMINI_API_KEY=your_gemini_api_key_here
# Free tier: 1500 requests/day, 1M tokens/min (as of 2025)
# Get key at: https://aistudio.google.com/app/apikey
