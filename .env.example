# ============================================================
# DocuIntel — Environment Variables
# Phase 1 + Phase 2 + Phase 3 + Phase 4
# Copy this file to .env and fill in your values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=DocuIntel
APP_VERSION=0.4.0
DEBUG=false
LOG_LEVEL=INFO

# ── Storage Paths ────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Embedding Model (local, no API key needed) ────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── Chunking ─────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_COLLECTION_NAME=documents

# ── Phase 2 Retrieval (preserved for backward compat) ─────────
RETRIEVAL_TOP_K=5

# ── Gemini (Phase 2) ─────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyAdjaucKe2NKrgBSWhpKTQsqaeE9qkA-Cw
GEMINI_MODEL=gemini-2.5-flash

# ── Phase 3: Hybrid retrieval ─────────────────────────────────
# How many candidates to pull from each index before merging.
# Larger values = better recall, slightly slower.
VECTOR_TOP_K=10
BM25_TOP_K=10

# Hybrid score weights.  Must sum to 1.0 for interpretable scores.
# Raise SEMANTIC_WEIGHT for concept-heavy queries.
# Raise BM25_WEIGHT for exact-term queries (names, codes, section numbers).
SEMANTIC_WEIGHT=0.6
BM25_WEIGHT=0.4

# ── Phase 3: Query rewriting ──────────────────────────────────
# Set to false to disable rewriting and save ~half your daily Gemini quota.
# When false: retrieval_query = original question (zero extra API calls).
ENABLE_QUERY_REWRITING=true

# ── Phase 3: Conversation memory ──────────────────────────────
# How many prior Q&A turns to include in each LLM prompt.
# Each turn = 1 user question + 1 assistant answer.
# Increase for longer conversations; decrease to save tokens.
MAX_MEMORY_TURNS=5

# ── Phase 4: OCR (Optical Character Recognition) ──────────────
# OCR support for scanned PDFs and image-based pages.
# Requires tesseract binary installed on your system:
#   Ubuntu/Debian:  sudo apt-get install tesseract-ocr
#   macOS:          brew install tesseract
#   Windows:        Download installer from https://github.com/UB-Mannheim/tesseract/wiki

# Enable OCR fallback for pages with no extractable text.
# When enabled (true): automatically OCR'd scanned pages are seamlessly included.
# When disabled (false): scanned pages are skipped (Phase 3 behaviour).
OCR_ENABLED=true

# Tesseract language code.  "eng" is always present.
# For other languages, install the data pack:
#   sudo apt-get install tesseract-ocr-<lang>
# Multiple languages: "eng+fra" (English + French)
# Full list: https://github.com/UB-Mannheim/tesseract/wiki/Data-Files
OCR_LANGUAGE=eng

# DPI (dots per inch) used when rendering PDF pages for OCR.
# 300 is standard for OCR — good balance of accuracy and speed.
# 150: faster but degrades on small fonts.
# 400+: marginal gains with much higher memory use.
OCR_DPI=300

