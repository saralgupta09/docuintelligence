# ============================================================
# DocuIntel — Environment Variables
# Phase 1 + Phase 2 + Phase 3
# Copy this file to .env and fill in your values.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=DocuIntel
APP_VERSION=0.3.0
DEBUG=false
LOG_LEVEL=INFO

# ── Storage Paths ────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
CHROMA_PERSIST_DIR=./data/chroma_db

# ── Embedding Model (local, no API key needed) ────────────────
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── Chunking ─────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_COLLECTION_NAME=documents

# ── Phase 2 Retrieval (preserved for backward compat) ─────────
RETRIEVAL_TOP_K=5

# ── Gemini (Phase 2) ─────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Phase 3: Hybrid retrieval ─────────────────────────────────
# How many candidates to pull from each index before merging.
# Larger values = better recall, slightly slower.
VECTOR_TOP_K=10
BM25_TOP_K=10

# Hybrid score weights.  Must sum to 1.0 for interpretable scores.
# Raise SEMANTIC_WEIGHT for concept-heavy queries.
# Raise BM25_WEIGHT for exact-term queries (names, codes, section numbers).
SEMANTIC_WEIGHT=0.6
BM25_WEIGHT=0.4

# ── Phase 3: Query rewriting ──────────────────────────────────
# Set to false to disable rewriting and save ~half your daily Gemini quota.
# When false: retrieval_query = original question (zero extra API calls).
ENABLE_QUERY_REWRITING=true

# ── Phase 3: Conversation memory ──────────────────────────────
# How many prior Q&A turns to include in each LLM prompt.
# Each turn = 1 user question + 1 assistant answer.
# Increase for longer conversations; decrease to save tokens.
MAX_MEMORY_TURNS=5
